# n-dx — runtime artifacts and ephemeral state
#
# Drop this block into your project's .gitignore after running `ndx init`.
#
# What to KEEP in git:
#   .rex/prd_tree/          ← PRD storage (always commit)
#   .rex/config.json        ← rex project config
#   .hench/config.json      ← agent config (model, max turns)
#   CLAUDE.md / AGENTS.md   ← assistant instruction files
#
# Optional commits (see docs/guide/gitignore.md for the tradeoffs):
#   .sourcevision/          ← commit to share analysis baseline with teammates
#   .n-dx.json              ← commit if it contains no secrets
#   .codex/config.toml      ← commit if your team uses Codex

# Analysis output (regenerated by `ndx analyze`)
.sourcevision/

# Agent runs, locks, and session state
.hench/runs/
.hench/locks/
.hench-commit-msg.txt

# Rex ephemeral state
.rex/.backups/
.rex/.cache/
.rex/prd.json.lock
.rex/pending-proposals.json
.rex/acknowledged-findings.json
.rex/execution-log*.jsonl
.rex/adapters.json
.rex/n-dx_workflow.md

# Server runtime
.n-dx-web.pid
.n-dx-web.port

# Run logs
.run-logs/

# Local config overrides (may contain secrets or API keys)
.n-dx.local.json
*.local.json

# Assistant local settings (personal, not shared)
.claude/settings.local.json
